#version 450
layout(local_size_x=16,local_size_y=16) in;
layout(set=0,binding=0) uniform sampler2D sourceImage;
layout(rgba16f,set=0,binding=1) uniform writeonly image2D destinationImage;
layout(push_constant) uniform Parameters { ivec2 outputExtent; ivec2 sourceExtent; int antiRinging; } p;
const float PI=3.14159265358979323846;float sinc(float x){if(abs(x)<1e-5)return 1.0;float q=PI*x;return sin(q)/q;}float lanczos(float x){x=abs(x);return x<2.0?sinc(x)*sinc(x*0.5):0.0;}
vec3 loadAt(ivec2 q){return texelFetch(sourceImage,clamp(q,ivec2(0),p.sourceExtent-1),0).rgb;}
void main(){ivec2 d=ivec2(gl_GlobalInvocationID.xy);if(any(greaterThanEqual(d,p.outputExtent)))return;vec2 s=(vec2(d)+0.5)*vec2(p.sourceExtent)/vec2(p.outputExtent)-0.5;ivec2 b=ivec2(floor(s));vec2 f=s-vec2(b);vec3 c=vec3(0),lo=vec3(1e20),hi=vec3(-1e20);float sum=0;for(int y=-1;y<=2;++y)for(int x=-1;x<=2;++x){vec3 v=loadAt(b+ivec2(x,y));float k=lanczos(float(x)-f.x)*lanczos(float(y)-f.y);c+=v*k;sum+=k;if(x>=0&&x<=1&&y>=0&&y<=1){lo=min(lo,v);hi=max(hi,v);}}c/=abs(sum)>1e-8?sum:1.0;if(p.antiRinging!=0)c=clamp(c,lo,hi);imageStore(destinationImage,d,vec4(c,1));}
